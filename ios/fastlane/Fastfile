# ./ios/fastlane/Fastfile
require 'dotenv/load'

Dotenv.load(
  File.expand_path('../.env', __dir__),
  File.expand_path('../../.env', __dir__)
)

default_platform(:ios)

platform :ios do
  before_all do
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_CONTENT"],
      is_key_content_base64: true
    )
  end

  def bundle_exec(command, gemfile: nil)
    brew_bundle = "/opt/homebrew/opt/ruby/bin/bundle"
    bundle_bin = File.exist?(brew_bundle) ? brew_bundle : "bundle"
    if gemfile
      sh "BUNDLE_GEMFILE=#{gemfile} #{bundle_bin} exec #{command}"
    else
      sh "#{bundle_bin} exec #{command}"
    end
  end

  # --- pubspec.yaml version helpers ---

  def read_pubspec_version(pubspec_path)
    content = File.read(pubspec_path)
    m = content.match(/^version:\s*([0-9]+\.[0-9]+\.[0-9]+)\+([0-9]+)\s*$/)
    UI.user_error!("pubspec.yaml에서 version 라인을 찾지 못했습니다: #{pubspec_path}") unless m
    { name: m[1], build: m[2].to_i }
  end

  def write_pubspec_version(pubspec_path, version_name, build_number)
    content = File.read(pubspec_path)
    new_line = "version: #{version_name}+#{build_number}"
    new_content = content.gsub(/^version:\s*[0-9]+\.[0-9]+\.[0-9]+\+\d+\s*$/, new_line)
    UI.user_error!("pubspec.yaml version 라인 치환에 실패했습니다: #{pubspec_path}") if new_content == content
    File.write(pubspec_path, new_content)
  end

  def current_release_info(project_root)
    current = read_pubspec_version(File.join(project_root, "pubspec.yaml"))
    {
      version_name: current[:name],
      build_number: current[:build],
      release_version: "#{current[:name]}+#{current[:build]}"
    }
  end

  def env_flag(key, default: false)
    value = ENV[key]
    return default if value.nil? || value.strip.empty?

    %w[1 true yes y on].include?(value.strip.downcase)
  end

  def env_int(key, default:)
    value = ENV[key]
    return default if value.nil? || value.strip.empty?

    Integer(value, 10)
  rescue ArgumentError
    UI.user_error!("환경 변수 #{key}는 정수여야 합니다. 현재 값: #{value}")
  end

  def upload_to_testflight!(ipa_path:, app_identifier:, release_info:, default_changelog:)
    wait_for_processing = env_flag("TESTFLIGHT_WAIT_FOR_PROCESSING", default: true)
    distribute_external = env_flag("TESTFLIGHT_DISTRIBUTE_EXTERNAL", default: false)
    notify_external_testers = env_flag("TESTFLIGHT_NOTIFY_EXTERNAL_TESTERS", default: false)
    wait_processing_interval = env_int("TESTFLIGHT_WAIT_PROCESSING_INTERVAL", default: 30)
    wait_processing_timeout = env_int("TESTFLIGHT_WAIT_PROCESSING_TIMEOUT", default: 5400)

    changelog = ENV["TESTFLIGHT_CHANGELOG"]
    changelog = default_changelog if changelog.nil? || changelog.strip.empty?

    pilot_options = {
      ipa: ipa_path,
      app_identifier: app_identifier,
      app_version: release_info[:version_name],
      build_number: release_info[:build_number].to_s,
      uses_non_exempt_encryption: false
    }

    if wait_for_processing
      UI.message(
        "⏳ TestFlight processing 완료까지 대기합니다. " \
        "release=#{release_info[:release_version]}, timeout=#{wait_processing_timeout}s"
      )

      pilot_options[:skip_waiting_for_build_processing] = false
      pilot_options[:distribute_external] = distribute_external
      pilot_options[:wait_processing_interval] = wait_processing_interval
      pilot_options[:wait_processing_timeout_duration] = wait_processing_timeout
      pilot_options[:changelog] = changelog unless changelog.nil? || changelog.strip.empty?
      pilot_options[:notify_external_testers] = notify_external_testers if distribute_external
    else
      UI.important(
        "TESTFLIGHT_WAIT_FOR_PROCESSING=false 이므로 업로드만 수행합니다. " \
        "테스터 배포와 changelog 반영은 건너뜁니다."
      )

      pilot_options[:skip_waiting_for_build_processing] = true
    end

    pilot(**pilot_options)
  end

  # TestFlight 최신 build와 pubspec build를 비교해서 next build를 결정하고 pubspec을 갱신
  # 반환: { version_name: "1.0.1", build_number: 40, release_version: "1.0.1+40" }
  def bump_pubspec_build_number!(app_identifier:, project_root:)
    pubspec_path = File.join(project_root, "pubspec.yaml")
    current = read_pubspec_version(pubspec_path)

    latest_build = 0
    begin
      latest_build = latest_testflight_build_number(app_identifier: app_identifier).to_i
    rescue => e
      UI.message("latest_testflight_build_number 조회 실패(초기 배포일 수 있음): #{e.message}")
      latest_build = 0
    end

    next_build = [latest_build, current[:build]].max + 1

    UI.message("pubspec current: #{current[:name]}+#{current[:build]}")
    UI.message("testflight latest: #{latest_build}")
    UI.message("next build number: #{next_build}")

    write_pubspec_version(pubspec_path, current[:name], next_build)

    {
      version_name: current[:name],
      build_number: next_build,
      release_version: "#{current[:name]}+#{next_build}"
    }
  end

  def ensure_pods_installed!(project_root)
    ios_gemfile = File.join(project_root, "ios", "Gemfile")
    Dir.chdir(File.join(project_root, "ios")) do
      bundle_exec "pod --version", gemfile: ios_gemfile
      bundle_exec "pod install", gemfile: ios_gemfile
    end
  end

  def find_latest_ipa(project_root)
    ipa = Dir.glob("#{project_root}/build/ios/ipa/*.ipa").max_by { |f| File.mtime(f) }
    UI.user_error!("IPA 파일을 찾을 수 없습니다. 빌드가 성공했는지 확인해주세요.") unless ipa
    ipa
  end

  # -------------------------
  # Lane 1) Flutter 빌드 -> TestFlight
  # -------------------------
  desc "Flutter 앱을 빌드하고 TestFlight에 배포합니다. (pubspec build 자동 증가)"
  lane :deploy_to_testflight do
    app_identifier = ENV["APP_IDENTIFIER"] || "com.newdawn.soi-project"
    project_root = File.expand_path("../..", __dir__)
    ios_gemfile = File.join(project_root, "ios", "Gemfile")

    bumped = bump_pubspec_build_number!(app_identifier: app_identifier, project_root: project_root)
    UI.message("✅ Using version: #{bumped[:release_version]}")

    ensure_pods_installed!(project_root)

    Dir.chdir(project_root) do
      bundle_exec "flutter pub get", gemfile: ios_gemfile
      # pubspec 버전을 그대로 사용 (오버라이드 X) -> iOS/ASC/shorebird와 일치 보장
      bundle_exec "flutter build ipa --release", gemfile: ios_gemfile
    end

    ipa_path = find_latest_ipa(project_root)
    UI.message("IPA: #{ipa_path}")
    release_info = current_release_info(project_root)
    UI.message("✅ Final release for upload: #{release_info[:release_version]}")

    upload_to_testflight!(
      ipa_path: ipa_path,
      app_identifier: app_identifier,
      release_info: release_info,
      default_changelog: "이번 버전의 테스트 변경 사항입니다."
    )
  end

  # -------------------------
  # Lane 2) Shorebird release -> TestFlight
  # -------------------------
  desc "Shorebird로 빌드하고 App Store Connect(TestFlight)에 업로드합니다. (pubspec build 자동 증가 + 버전 일치 보장)"
  lane :upload_shorebird do
    app_identifier = ENV["APP_IDENTIFIER"] || "com.newdawn.soi-project"
    project_root = File.expand_path("../..", __dir__)
    ios_gemfile = File.join(project_root, "ios", "Gemfile")

    bumped = bump_pubspec_build_number!(app_identifier: app_identifier, project_root: project_root)
    UI.message("✅ Using version: #{bumped[:release_version]}")

    ensure_pods_installed!(project_root)

    Dir.chdir(project_root) do
      bundle_exec "flutter pub get", gemfile: ios_gemfile

      UI.message("🐦 Shorebird로 iOS 빌드 시작...")
      begin
        sh "shorebird release ios"
      rescue FastlaneCore::Interface::FastlaneShellError => e
        # 동일 릴리즈가 이미 Shorebird에 있는 경우를 안전하게 한 번 더 처리
        if e.message.include?("existing ios release for version")
          UI.message("⚠️ Shorebird에 동일 릴리즈가 이미 존재하여 build를 한 번 더 올립니다.")
          # pubspec build +1 후 재시도
          current = read_pubspec_version(File.join(project_root, "pubspec.yaml"))
          write_pubspec_version(File.join(project_root, "pubspec.yaml"), current[:name], current[:build] + 1)
          UI.message("🔁 Retrying with version: #{current[:name]}+#{current[:build] + 1}")
          sh "shorebird release ios"
        else
          raise
        end
      end
    end

    UI.success("✅ Shorebird 빌드 완료!")

    ipa_path = find_latest_ipa(project_root)
    UI.success("✅ IPA 파일: #{ipa_path}")

    file_size_mb = File.size(ipa_path) / (1024.0 * 1024.0)
    UI.message("📦 IPA 크기: #{file_size_mb.round(1)} MB")

    UI.message("🚀 App Store Connect 업로드 시작...")
    release_info = current_release_info(project_root)
    UI.message("✅ Final release for upload: #{release_info[:release_version]}")

    upload_to_testflight!(
      ipa_path: ipa_path,
      app_identifier: app_identifier,
      release_info: release_info,
      default_changelog: "Shorebird로 배포된 버전입니다."
    )

    UI.success("✅ 모든 작업 완료!")
  end
end
